# Supabase (required for the app)
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# IMPORTANT: Copy the anon key exactly — no spaces or line breaks.
# The key must match your project URL. If you see "Invalid API key" on
# registration, re-copy the key from the dashboard.

# Database URL for migrations only (do not expose in frontend)
# Encode special characters in password: @ → %40, # → %23, $ → %24
# Example: postgresql://postgres:Irfan%40%23%24123@db.faxjlprxfdbpncbepdxy.supabase.co:5432/postgres
# Use pooler if direct db.* host is unreachable (region: ap-southeast-2):
# postgresql://postgres.faxjlprxfdbpncbepdxy:YOUR_ENCODED_PASSWORD@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=
